adakitte <- read_sas(file.path(here::here("rstudio/Data"),"adakitte.sas7bdat"))
adtte0 <- adakitte |> 
  filter(PARAM=="eGFR - Time to first Grade 1(at least Grade 1) in Month (Treatment)") |> 
  select(USUBJID,TRTP,PARAMCD,STARTDT,ADT,AVAL,CNSR)

adtte0 <- adtte0 |> 
  mutate(TRTP = factor(TRTP, levels = c("Placebo","Mindaptin Low Dose","Mindaptin High Dose")))

# 查看TRTP的水平和顺序
unique(adtte0$TRTP)
levels(adtte0$TRTP)
table(adtte0$TRTP)

fit <- survfit(Surv(AVAL, 1 - CNSR) ~ TRTP, data = adtte0)
# 在绘图之前修改 fit 对象的 strata 名称
names(fit$strata) <- gsub("TRTP=", "", names(fit$strata))

# 设置统一的x轴范围
x_limits <- c(0, max(adtte0$AVAL, na.rm = TRUE))
x_breaks <- seq(0, ceiling(max(adtte0$AVAL, na.rm = TRUE)), by = 2)

# 自定义颜色
custom_colors <- c("#619CFF", "#00BA38", "#F8766D")  # 红、蓝、绿

p <- ggsurvplot(
  fit,
  data = adtte0,
  fun = "event",
  conf.int = FALSE,
  #pval = TRUE,
  risk.table = TRUE,
  cumevents = TRUE,
  tables.height = 0.25,
  risk.table.height = 0.15,
  cumevents.height = 0.15,
  legend.title = "Treatment",
  xlab = "Time from first dose (months)",
  ylab = " ",
  title = " ",
  palette = custom_colors,
  ggtheme = theme_bw(),
  tables.theme = theme_cleantable(),
  fontsize = 4,  # 调整字体大小以改善对齐
  tables.y.text = TRUE,  # 显示表格Y轴文本
  legend = "bottom"
)
# 删除主图背景网格线并设置纵轴刻度
p$plot <- p$plot + 
  ylab("Cumulative Percentage (%) of
eGFR >=25% Decrease from
Last Known Value on Treatment") +
  scale_x_continuous(
    breaks = x_breaks,
    limits = x_limits
  ) +
  scale_y_continuous(
    breaks = seq(0, 0.15, by = 0.05),
    labels = sprintf("%.2f", seq(0, 0.15, by = 0.05)),
    limits = c(0, 0.2)
  ) +
  theme(
    axis.text.y = element_text(margin = margin(r = 0)),
    axis.title.y = element_text(margin = margin(r = 0)),
    plot.margin = margin(5, 10, 5, 10, "pt"),
    panel.grid.major = element_blank(),
    panel.grid.minor = element_blank(),
    panel.background = element_blank(),
    panel.border = element_blank(),  # 移除整个边框
    axis.line.x = element_line(colour = "black", linewidth = 0.5),  # 保留x轴线
    axis.line.y = element_line(colour = "black", linewidth = 0.5)   # 保留y轴线
#   panel.border = element_rect(colour = "black", fill = NA, linewidth = 1)
  )
# 删除风险表和累积事件表的背景框线
p$table <- p$table + 
  labs(title = "Number of Subjects at Risk") +  # 修改标题
  scale_x_continuous(
    breaks = x_breaks,
    limits = x_limits
  ) +
  theme(
    plot.margin = margin(5, 10, 5, 42, "pt"),
    panel.grid.major = element_blank(),
    panel.grid.minor = element_blank(),
    panel.background = element_blank(),
    panel.border = element_rect(colour = "black", fill = NA, linewidth = 0.5),
    axis.line = element_blank()
  )

p$cumevents <- p$cumevents + 
  labs(title = "Cumulative Number of Subjects with Event") +  # 修改标题
  scale_x_continuous(
    breaks = x_breaks,
    limits = x_limits
  ) +
  theme(
    plot.margin = margin(5, 10, 5, 42, "pt"),
    panel.grid.major = element_blank(),
    panel.grid.minor = element_blank(),
    panel.background = element_blank(),
    panel.border = element_rect(colour = "black", fill = NA, linewidth = 0.5),
    axis.line = element_blank()
  )

# 提取置信区间数据 - 找最接近的时间点
time_points <- c(2, 4, 6)
surv_summary <- surv_summary(fit, data = adtte0)

ci_data <- do.call(rbind, lapply(time_points, function(tp) {
  surv_summary |>
    group_by(strata) |>
    mutate(time_diff = abs(time - tp)) |>
    filter(time_diff == min(time_diff)) |>
    slice(1) |>
    mutate(target_time = tp) |>
    ungroup()
})) |>
  mutate(
    cumulative = 1 - surv,
    lower_ci = 1 - upper,
    upper_ci = 1 - lower
  )

# 在主图上添加置信区间标记
p$plot <- p$plot +
  geom_errorbar(
    data = ci_data,
    aes(x = target_time, ymin = lower_ci, ymax = upper_ci, color = strata),
    width = 0.2,
    linewidth = 0.8,
    show.legend = FALSE
  )

# 为风险表添加分组颜色 - 修改文本图层
p$table$layers[[1]]$aes_params$colour <- custom_colors[as.numeric(factor(p$data.survtable$strata))]

# 为累积事件表添加分组颜色 - 修改文本图层  
p$cumevents$layers[[1]]$aes_params$colour <- custom_colors[as.numeric(factor(p$data.survtable$strata))]

print(p)

png("f_km_YHY.png", width = 297, height = 210, units = "mm", res = 300)
