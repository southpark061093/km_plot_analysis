# 创建一个函数来详细检查图层
inspect_layer <- function(layer) {
  cat("=== 图层详细参数 ===\n\n")
  
  cat("1. 几何对象类型:\n")
  print(class(layer$geom))
  
  cat("\n2. 美学参数 (aes_params):\n")
  print(layer$aes_params)
  
  cat("\n3. 美学映射 (mapping):\n")
  print(layer$mapping)
  
  cat("\n4. 几何对象参数 (geom_params):\n")
  print(layer$geom_params)
  
  cat("\n5. 统计参数 (stat_params):\n")
  print(layer$stat_params)
  
  cat("\n6. 默认美学 (default_aes):\n")
  print(layer$geom$default_aes)
  
  cat("\n7. 数据维度:\n")
  print(dim(layer$data))
  
  cat("\n8. 数据预览:\n")
  print(head(layer$data))
}

# 使用函数检查第1个图层
inspect_layer(p$table$layers[[1]])

